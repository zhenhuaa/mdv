{
  "name": "mdv",
  "version": "1.1.3",
  "license": "MIT",
  "description": "Terminal Markdown browser with Mermaid rendering, plus a Mermaid SVG/ASCII rendering library.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mdv": "./src/mdv.ts"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zhenhuaa/mdc.git"
  },
  "homepage": "https://github.com/zhenhuaa/mdc",
  "bugs": {
    "url": "https://github.com/zhenhuaa/mdc/issues"
  },
  "keywords": [
    "markdown",
    "markdown-viewer",
    "markdown-browser",
    "terminal",
    "terminal-markdown",
    "cli",
    "mdv",
    "mermaid",
    "diagram",
    "svg",
    "ascii",
    "flowchart",
    "sequence-diagram",
    "class-diagram",
    "er-diagram",
    "xychart",
    "state-diagram",
    "visualization",
    "theming"
  ],
  "author": "zhenhuaa",
  "files": ["src/", "dist/", "LICENSE", "README.md"],
  "scripts": {
    "test": "bun test src/__tests__/",
    "samples": "bun run index.ts",
    "dev": "bun run dev.ts",
    "bench": "bun run bench.ts",
    "build": "tsup",
    "build:samples": "bun run index.ts && mkdir -p site && mv index.html site/ && cp -r public/* site/",
    "deploy": "bun run build:samples && wrangler pages deploy site --project-name mdv",
    "xychart-test": "bun run xychart-test.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "elkjs": "^0.11.0",
    "entities": "^7.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "shiki": "^3.19.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
